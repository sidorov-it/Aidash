{
  "name": "lao",
  "version": "0.1.0",
  "description": "Local AI Dev Orchestrator — local-first desktop app for managing AI coding agents",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "tsc",
    "build:ui": "vite build --config ui/vite.config.ts",
    "build:all": "npm run build && npm run build:ui",
    "start": "node dist/index.js",
    "start:desktop": "npm run build:all && electron .",
    "dev": "ts-node src/index.ts",
    "dev:ui": "vite --config ui/vite.config.ts",
    "dev:electron": "VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:desktop": "concurrently -n ui,electron -c blue,green \"npm run dev:ui\" \"sleep 3 && npm run dev:electron\"",
    "test": "jest --forceExit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "express": "^4.21.0",
    "express-ws": "^5.0.2",
    "simple-git": "^3.27.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-ws": "^3.0.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.0",
    "prisma": "^5.20.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "zustand": "^5.0.0"
  }
}
